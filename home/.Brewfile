brew "gh"
brew "ggshield"
brew "git"
brew "git-lfs"

# Modern CLI utilities
brew "bat"
brew "eza"
brew "fd"
brew "fzf"
brew "jq"
brew "ripgrep"
brew "zoxide"

# Networking
brew "curl"
brew "nmap"
brew "wget"

# Build tools
brew "cmake"
brew "gcc"

# Version managers
brew "asdf"

# Databases
brew "mysql"
brew "redis"

